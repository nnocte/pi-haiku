{
  "name": "pi-haiku",
  "version": "0.2.0",
  "description": "A warm, minimal theme plus a structured footer and keymap header replacement for Pi coding agent. Bundles the 'haiku' theme with a footer that surfaces location, model, context, tokens, cache, and cost — and a startup keymap that stays readable on any terminal width.",
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "pi-extension",
    "pi-theme",
    "theme",
    "footer",
    "header",
    "tui",
    "minimal"
  ],
  "license": "MIT",
  "author": "nocte <nocte19@gmail.com>",
  "type": "module",
  "files": [
    "extensions/",
    "themes/",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ],
    "themes": [
      "./themes"
    ],
    "image": "https://raw.githubusercontent.com/nnocte/pi-haiku/main/screenshots/haiku-1.png"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nnocte/pi-haiku.git"
  },
  "homepage": "https://github.com/nnocte/pi-haiku#readme",
  "bugs": {
    "url": "https://github.com/nnocte/pi-haiku/issues"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-tui": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
